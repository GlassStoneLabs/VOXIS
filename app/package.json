{
  "name": "voxis",
  "private": true,
  "version": "4.0.0",
  "productName": "Voxis 4.0 DENSE",
  "description": "VOXIS 4.0 DENSE — Professional Voice Restoration powered by Trinity V8.1",
  "author": {
    "name": "Glass Stone LLC",
    "email": "info@glassstone.dev"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently -k \"vite\" \"tsc -p electron/tsconfig.json -w\" \"electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:build:win": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:compile && electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.35.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/cli": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "build": {
    "appId": "com.glassstone.voxis",
    "productName": "Voxis 4.0 DENSE",
    "publish": {
      "provider": "github",
      "owner": "GlassStoneLabs",
      "repo": "VOXIS"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "resources/icons/icon.icns",
      "minimumSystemVersion": "12.0",
      "darkModeSupport": false,
      "extraResources": [
        { "from": "resources/bin/trinity_v8_core", "to": "bin/trinity_v8_core" }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "extraResources": [
        { "from": "resources/bin/trinity_v8_core.exe", "to": "bin/trinity_v8_core.exe" },
        { "from": "resources/bin/ffmpeg.exe", "to": "bin/ffmpeg.exe" },
        { "from": "resources/bin/ffprobe.exe", "to": "bin/ffprobe.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voxis 4.0 DENSE"
    },
    "dmg": {
      "title": "VOXIS 4.0 DENSE — Voice Restoration",
      "icon": "resources/icons/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "copyright": "Copyright (c) 2026 Glass Stone LLC. All Rights Reserved."
  }
}
