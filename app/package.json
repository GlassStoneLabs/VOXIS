{
  "name": "voxis",
  "private": true,
  "version": "4.0.0",
  "description": "VOXIS 4.0 DENSE — Professional Audio Restoration powered by Trinity V8.1",
  "author": {
    "name": "Glass Stone LLC",
    "email": "info@glassstone.dev"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently -k \"vite\" \"tsc -p electron/tsconfig.json -w\" \"electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "framer-motion": "^12.35.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "build": {
    "appId": "com.glassstone.voxis",
    "productName": "Voxis",
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "resources/icons/icon.icns",
      "minimumSystemVersion": "12.0",
      "darkModeSupport": false
    },
    "dmg": {
      "title": "VOXIS",
      "icon": "resources/icons/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin/trinity_v8_core",
        "to": "bin/trinity_v8_core"
      }
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "copyright": "Copyright (c) 2026 Glass Stone LLC. All Rights Reserved."
  }
}
