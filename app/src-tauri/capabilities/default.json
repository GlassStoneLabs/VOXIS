{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Voxis 4.0 DENSE — Main Window Capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/trinity_v8_core",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
