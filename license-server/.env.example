# VOXIS License Server — Environment Configuration
# Copy to .env and fill in real values before deploying

# Server
PORT=3847

# Change this before deploying — used to sign JWT tokens
JWT_SECRET=change-this-to-a-long-random-string-before-production

# Change this — used to derive license key HMACs
LICENSE_HMAC_SECRET=change-this-to-another-long-random-string

# Change this — protects all /admin/* routes
ADMIN_KEY=change-this-admin-key

# SQLite database path (absolute or relative to server.js)
# Default: ~/.voxis-server/licenses.db
# DB_PATH=/var/data/voxis/licenses.db

# Token validity in days (offline grace = 7 days)
TOKEN_TTL_DAYS=7

# CORS origins allowed (comma-separated, or * for any)
# In production lock this to your app's origin
ALLOWED_ORIGINS=*
